				"typeProperties": {
					"frequency": "Minute",
					"interval": 5,
					"startTime": "2026-05-20T10:20:00Z",
					"endTime": "2026-05-20T10:30:00Z",
					"delay": "00:00:00",
					"maxConcurrency": 50,
					"retryPolicy": {
